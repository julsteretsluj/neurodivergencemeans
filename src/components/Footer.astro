---
import { site } from "../data/site";
---

<footer class="site-footer">
  <div class="wrap footer-inner">
    <div>
      <p class="footer-brand">{site.name}</p>
      <p class="footer-copy">Posts live on Instagram. This site gathers them in one place.</p>
    </div>
    <div class="footer-links">
      <a href={site.instagramUrl} target="_blank" rel="noopener noreferrer">Instagram {site.handle}</a>
      <a href="/resources/">Resources</a>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: auto;
    border-top: 1px solid var(--line);
    padding: 2.5rem 0;
    background: color-mix(in oklab, var(--foam) 35%, transparent);
  }

  .footer-inner {
    display: grid;
    gap: 1.5rem;
  }

  .footer-brand {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.25rem;
    letter-spacing: -0.03em;
    margin-bottom: 0.35rem;
  }

  .footer-copy {
    color: var(--ink-soft);
    max-width: 28rem;
    margin: 0;
  }

  .footer-links {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem 1.5rem;
  }

  .footer-links a {
    font-weight: 700;
    text-decoration: none;
  }

  @media (min-width: 760px) {
    .footer-inner {
      grid-template-columns: 1.4fr 1fr;
      align-items: end;
    }

    .footer-links {
      justify-content: flex-end;
    }
  }
</style>
