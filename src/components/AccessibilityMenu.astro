<details class="accessibility-menu">
  <summary aria-label="Open accessibility options">
    <span aria-hidden="true">♿</span>
    <span>Accessibility</span>
  </summary>

  <div class="accessibility-panel">
    <h2>♿ Accessibility options</h2>

    <label for="accessibility-text-size">🔤 Text size</label>
    <select id="accessibility-text-size">
      <option value="default">Default</option>
      <option value="large">Large</option>
      <option value="larger">Larger</option>
    </select>

    <label class="toggle">
      <input id="accessibility-contrast" type="checkbox" />
      <span>◐ High contrast</span>
    </label>

    <label class="toggle">
      <input id="accessibility-motion" type="checkbox" />
      <span>⏸️ Reduce motion</span>
    </label>

    <label class="toggle">
      <input id="accessibility-links" type="checkbox" />
      <span>🔗 Underline links</span>
    </label>

    <button id="accessibility-reset" type="button">↺ Reset options</button>
    <p>💾 Choices are saved on this device.</p>
  </div>
</details>

<script>
  type Preferences = {
    textSize: "default" | "large" | "larger";
    highContrast: boolean;
    reduceMotion: boolean;
    underlineLinks: boolean;
  };

  const storageKey = "neurodivergence-means-accessibility";
  const defaults: Preferences = {
    textSize: "default",
    highContrast: false,
    reduceMotion: false,
    underlineLinks: false,
  };

  const textSize = document.querySelector<HTMLSelectElement>(
    "#accessibility-text-size",
  );
  const highContrast = document.querySelector<HTMLInputElement>(
    "#accessibility-contrast",
  );
  const reduceMotion = document.querySelector<HTMLInputElement>(
    "#accessibility-motion",
  );
  const underlineLinks = document.querySelector<HTMLInputElement>(
    "#accessibility-links",
  );
  const reset = document.querySelector<HTMLButtonElement>(
    "#accessibility-reset",
  );

  function readPreferences(): Preferences {
    try {
      const saved = JSON.parse(localStorage.getItem(storageKey) ?? "{}");
      return { ...defaults, ...saved };
    } catch {
      return defaults;
    }
  }

  function applyPreferences(preferences: Preferences) {
    const root = document.documentElement;
    root.dataset.textSize = preferences.textSize;
    root.toggleAttribute("data-high-contrast", preferences.highContrast);
    root.toggleAttribute("data-reduce-motion", preferences.reduceMotion);
    root.toggleAttribute("data-underline-links", preferences.underlineLinks);

    if (textSize) textSize.value = preferences.textSize;
    if (highContrast) highContrast.checked = preferences.highContrast;
    if (reduceMotion) reduceMotion.checked = preferences.reduceMotion;
    if (underlineLinks) underlineLinks.checked = preferences.underlineLinks;
  }

  function currentPreferences(): Preferences {
    return {
      textSize:
        (textSize?.value as Preferences["textSize"]) ?? defaults.textSize,
      highContrast: highContrast?.checked ?? false,
      reduceMotion: reduceMotion?.checked ?? false,
      underlineLinks: underlineLinks?.checked ?? false,
    };
  }

  function saveAndApply() {
    const preferences = currentPreferences();
    applyPreferences(preferences);
    try {
      localStorage.setItem(storageKey, JSON.stringify(preferences));
    } catch {
      // The controls still work when browser storage is unavailable.
    }
  }

  applyPreferences(readPreferences());

  textSize?.addEventListener("change", saveAndApply);
  highContrast?.addEventListener("change", saveAndApply);
  reduceMotion?.addEventListener("change", saveAndApply);
  underlineLinks?.addEventListener("change", saveAndApply);
  reset?.addEventListener("click", () => {
    applyPreferences(defaults);
    try {
      localStorage.removeItem(storageKey);
    } catch {
      // Nothing else is required if storage is unavailable.
    }
  });
</script>

<style>
  .accessibility-menu {
    position: fixed;
    right: 1rem;
    bottom: 1rem;
    z-index: 100;
    font-family: var(--font-body);
    color: var(--ink);
  }

  .accessibility-menu > summary {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    width: fit-content;
    margin-left: auto;
    padding: 0.7rem 0.9rem;
    border: 2px solid var(--ink);
    border-radius: var(--radius);
    background: var(--paper);
    box-shadow: var(--shadow-soft);
    font-weight: 700;
    font-size: 0.9rem;
    cursor: pointer;
    list-style: none;
  }

  .accessibility-menu > summary::-webkit-details-marker {
    display: none;
  }

  .accessibility-menu > summary span:first-child {
    display: grid;
    place-items: center;
    width: 1.9rem;
    height: 1.9rem;
    border-radius: 50%;
    background: var(--ink);
    color: var(--paper);
    font-size: 1rem;
  }

  .accessibility-panel {
    width: min(20rem, calc(100vw - 2rem));
    margin-bottom: 0.65rem;
    padding: 1.1rem;
    border: 2px solid var(--ink);
    border-radius: var(--radius);
    background: var(--paper);
    box-shadow: var(--shadow-soft);
  }

  .accessibility-menu[open] {
    display: flex;
    flex-direction: column-reverse;
  }

  .accessibility-panel h2 {
    margin-bottom: 1rem;
    font-size: 1.25rem;
  }

  .accessibility-panel > label:not(.toggle) {
    display: block;
    margin-bottom: 0.3rem;
    font-weight: 700;
    font-size: 0.9rem;
  }

  select,
  button {
    width: 100%;
    min-height: 2.75rem;
    border: 1.5px solid var(--ink);
    border-radius: var(--radius);
    background: var(--paper);
    color: var(--ink);
    font: inherit;
  }

  select {
    margin-bottom: 1rem;
    padding: 0.45rem 0.6rem;
  }

  .toggle {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    min-height: 2.5rem;
    font-weight: 700;
    font-size: 0.92rem;
    cursor: pointer;
  }

  .toggle input {
    width: 1.2rem;
    height: 1.2rem;
    accent-color: var(--sea-deep);
  }

  button {
    margin-top: 0.8rem;
    padding: 0.5rem 0.75rem;
    font-weight: 700;
    cursor: pointer;
  }

  button:hover {
    background: var(--ink);
    color: var(--paper);
  }

  .accessibility-panel p {
    margin: 0.65rem 0 0;
    color: var(--ink-soft);
    font-size: 0.8rem;
  }
</style>
