---
import BaseLayout from "../layouts/BaseLayout.astro";
import InstagramFeed from "../components/InstagramFeed.astro";
import { site } from "../data/site";
import { posts } from "../data/posts";
---

<BaseLayout>
  <section class="hero">
    <div class="wrap hero-grid">
      <div class="hero-content">
        <p class="handle animate-rise">{site.handle}</p>
        <h1 class="animate-rise animate-rise-delay-1">{site.name}</h1>
        <p class="lede animate-rise animate-rise-delay-2">{site.tagline}</p>
        <div class="btn-group animate-rise animate-rise-delay-3">
          <a class="btn btn-primary" href={site.instagramUrl} target="_blank" rel="noopener noreferrer">
            Follow on Instagram
          </a>
          <a class="btn btn-secondary" href="#posts">Browse posts</a>
        </div>
      </div>
      <div class="hero-figure animate-rise animate-rise-delay-2">
        <img
          src="/neurodivergence-means.png"
          alt="Hand-drawn rainbow infinity symbol with the words “Neurodivergence Means…”, surrounded by terms like ADHD, Autism, OCD, Dyslexia, and Tourette’s Syndrome"
          width="1024"
          height="1024"
        />
      </div>
    </div>
  </section>

  <section class="section" id="posts">
    <div class="wrap">
      <div class="section-head">
        <h2>Latest from Instagram</h2>
        <p>A curated feed from {site.handle} — open any post to view it on Instagram.</p>
      </div>
      <InstagramFeed posts={posts} />
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    position: relative;
    min-height: min(88vh, 50rem);
    display: grid;
    align-items: center;
    overflow: hidden;
    border-bottom: 1px solid var(--line);
    background:
      radial-gradient(ellipse 70% 60% at 80% 40%, color-mix(in oklab, var(--foam) 55%, transparent), transparent 70%);
  }

  .hero-grid {
    display: grid;
    gap: 2.5rem;
    align-items: center;
    padding: 5.5rem 0 3.5rem;
  }

  .hero-figure {
    order: -1;
    display: grid;
    justify-items: center;
  }

  .hero-figure img {
    width: min(100%, 30rem);
    height: auto;
    filter: drop-shadow(0 18px 36px color-mix(in oklab, var(--ink) 14%, transparent));
    animation: drift 6s ease-in-out infinite alternate;
  }

  .hero-content {
    max-width: 40rem;
  }

  @media (min-width: 900px) {
    .hero-grid {
      grid-template-columns: 1.15fr 1fr;
      gap: 3.5rem;
    }

    .hero-figure {
      order: 0;
    }

    .hero-figure img {
      width: min(100%, 34rem);
    }
  }

  .handle {
    font-family: var(--font-display);
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--sea-deep);
    margin-bottom: 0.75rem;
  }

  h1 {
    font-size: clamp(2.2rem, 5.6vw, 3.8rem);
    margin-bottom: 1rem;
  }

  .lede {
    font-size: clamp(1.1rem, 2.4vw, 1.3rem);
    color: var(--ink-soft);
    max-width: 34rem;
    margin-bottom: 1.6rem;
  }
</style>
