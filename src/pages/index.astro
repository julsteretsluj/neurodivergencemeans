---
import BaseLayout from "../layouts/BaseLayout.astro";
import InstagramFeed from "../components/InstagramFeed.astro";
import { site } from "../data/site";
import { posts } from "../data/posts";
import { categories } from "../data/categories";
---

<BaseLayout>
  <section class="hero">
    <div class="wrap hero-grid">
      <div class="hero-content">
        <p class="handle animate-rise">{site.handle}</p>
        <h1 class="animate-rise animate-rise-delay-1">{site.name}</h1>
        <p class="lede animate-rise animate-rise-delay-2">{site.tagline}</p>
        <div class="btn-group animate-rise animate-rise-delay-3">
          <a class="btn btn-primary" href={site.instagramUrl} target="_blank" rel="noopener noreferrer">
            Follow on Instagram
          </a>
          <a class="btn btn-secondary" href="#posts">Browse posts</a>
        </div>
      </div>
      <div class="hero-figure animate-rise animate-rise-delay-2">
        <img
          src="/neurodiversity-symbol.png"
          alt="Rainbow infinity symbol representing neurodiversity"
          width="1024"
          height="512"
        />
      </div>
    </div>
  </section>

  <section class="section" id="posts">
    <div class="wrap">
      <div class="section-head">
        <h2>Latest from Instagram</h2>
        <p>A curated feed from {site.handle} — open any post to view it on Instagram.</p>
      </div>
      <InstagramFeed posts={posts} />
    </div>
  </section>

  <section class="section categories-preview">
    <div class="wrap">
      <div class="section-head">
        <h2>Browse by category</h2>
        <p>Topic pages group posts so you can find language for specific parts of neurodivergence.</p>
      </div>
      <ul class="category-list">
        {
          categories.map((category) => (
            <li>
              <a href={`/categories/${category.slug}/`} style={`--accent: ${category.accent}`}>
                <span class="cat-title">{category.title}</span>
                <span class="cat-summary">{category.summary}</span>
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    position: relative;
    min-height: min(88vh, 50rem);
    display: grid;
    align-items: center;
    overflow: hidden;
    border-bottom: 1px solid var(--line);
    background:
      radial-gradient(ellipse 70% 60% at 80% 40%, color-mix(in oklab, var(--foam) 55%, transparent), transparent 70%);
  }

  .hero-grid {
    display: grid;
    gap: 2.5rem;
    align-items: center;
    padding: 5.5rem 0 3.5rem;
  }

  .hero-figure {
    order: -1;
    display: grid;
    justify-items: center;
  }

  .hero-figure img {
    width: min(100%, 30rem);
    height: auto;
    filter: drop-shadow(0 18px 36px color-mix(in oklab, var(--ink) 14%, transparent));
    animation: drift 6s ease-in-out infinite alternate;
  }

  .hero-content {
    max-width: 40rem;
  }

  @media (min-width: 900px) {
    .hero-grid {
      grid-template-columns: 1.15fr 1fr;
      gap: 3.5rem;
    }

    .hero-figure {
      order: 0;
    }

    .hero-figure img {
      width: min(100%, 34rem);
    }
  }

  .handle {
    font-family: var(--font-display);
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--sea-deep);
    margin-bottom: 0.75rem;
  }

  h1 {
    font-size: clamp(2.2rem, 5.6vw, 3.8rem);
    margin-bottom: 1rem;
  }

  .lede {
    font-size: clamp(1.1rem, 2.4vw, 1.3rem);
    color: var(--ink-soft);
    max-width: 34rem;
    margin-bottom: 1.6rem;
  }

  .categories-preview {
    padding-top: 0;
  }

  .category-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.85rem;
  }

  .category-list a {
    display: grid;
    gap: 0.35rem;
    padding: 1.15rem 0;
    border-top: 1px solid var(--line);
    text-decoration: none;
    color: inherit;
    transition: padding-left 180ms ease;
  }

  .category-list li:last-child a {
    border-bottom: 1px solid var(--line);
  }

  .category-list a:hover {
    padding-left: 0.4rem;
  }

  .cat-title {
    font-family: var(--font-display);
    font-size: 1.45rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    color: var(--accent, var(--ink));
  }

  .cat-summary {
    color: var(--ink-soft);
  }

  @media (min-width: 860px) {
    .category-list {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      column-gap: 2rem;
    }
  }
</style>
