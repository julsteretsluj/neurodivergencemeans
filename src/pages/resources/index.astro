---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { resources } from "../../data/resources";
import { categories } from "../../data/categories";
---

<BaseLayout title="Resources" description="Guides, tools, and organizations related to neurodivergence.">
  <section class="page-hero">
    <div class="wrap">
      <h1 class="animate-rise">Resources</h1>
      <p class="animate-rise animate-rise-delay-1">
        Practical starting points — not a complete map. Pair these with the Instagram posts when you want more depth.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="wrap">
      <ul class="resource-list">
        {
          resources.map((resource) => {
            const tags = categories.filter((category) =>
              resource.categorySlugs.includes(category.slug),
            );
            return (
              <li>
                <article class="resource">
                  <div class="resource-top">
                    <span class="type">{resource.type}</span>
                    <h2>
                      <a href={resource.href} target="_blank" rel="noopener noreferrer">
                        {resource.title}
                      </a>
                    </h2>
                  </div>
                  <p>{resource.description}</p>
                  <ul class="tags">
                    {tags.map((tag) => (
                      <li>
                        <a href={`/categories/${tag.slug}/`}>{tag.title}</a>
                      </li>
                    ))}
                  </ul>
                </article>
              </li>
            );
          })
        }
      </ul>
    </div>
  </section>
</BaseLayout>

<style>
  .page-hero {
    padding: 5rem 0 1rem;
    border-bottom: 1px solid var(--line);
    background:
      linear-gradient(180deg, color-mix(in oklab, var(--foam) 45%, transparent), transparent);
  }

  h1 {
    font-size: clamp(2.4rem, 7vw, 4rem);
  }

  .page-hero p {
    max-width: 36rem;
    color: var(--ink-soft);
    font-size: 1.15rem;
  }

  .resource-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 1.75rem;
  }

  .resource {
    padding-bottom: 1.75rem;
    border-bottom: 1px solid var(--line);
  }

  .resource-top {
    display: grid;
    gap: 0.35rem;
    margin-bottom: 0.55rem;
  }

  .type {
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--sea-deep);
  }

  h2 {
    font-size: clamp(1.4rem, 3vw, 1.85rem);
    margin: 0;
  }

  h2 a {
    text-decoration: none;
    color: var(--ink);
  }

  h2 a:hover {
    color: var(--sea-deep);
  }

  .resource p {
    color: var(--ink-soft);
    max-width: 42rem;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .tags a {
    font-weight: 700;
    text-decoration: none;
    font-size: 0.92rem;
  }

  @media (min-width: 900px) {
    .resource-list {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      column-gap: 2.5rem;
    }
  }
</style>
