---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { resourcePages } from "../../data/resources";
---

<BaseLayout title="📚 Resources" description="Curated resource collections related to neurodivergence.">
  <section class="page-hero">
    <div class="wrap">
      <h1 class="animate-rise">📚 Resources</h1>
      <p class="animate-rise animate-rise-delay-1">
        Curated collections of trusted organizations, guides, and reading — grouped by topic.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="wrap">
      <ul class="page-list">
        {
          resourcePages.map((page) => (
            <li>
              <a href={`/resources/${page.slug}/`}>
                <span class="count">📎 {page.links.length} resources</span>
                <h2>{page.title}</h2>
                <p>{page.intro}</p>
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </section>
</BaseLayout>

<style>
  .page-hero {
    padding: 5rem 0 1rem;
    border-bottom: 1px solid var(--line);
    background:
      linear-gradient(180deg, color-mix(in oklab, var(--foam) 45%, transparent), transparent);
  }

  h1 {
    font-size: clamp(2.4rem, 7vw, 4rem);
  }

  .page-hero p {
    max-width: 36rem;
    color: var(--ink-soft);
    font-size: 1.15rem;
  }

  .page-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 1rem;
  }

  .page-list a {
    display: grid;
    gap: 0.45rem;
    padding: 1.4rem 0;
    border-top: 1px solid var(--line);
    text-decoration: none;
    color: inherit;
  }

  .page-list li:last-child a {
    border-bottom: 1px solid var(--line);
  }

  .count {
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--sea-deep);
  }

  h2 {
    font-size: clamp(1.6rem, 3.5vw, 2.1rem);
    margin: 0;
  }

  .page-list a:hover h2 {
    color: var(--sea-deep);
  }

  .page-list p {
    margin: 0;
    color: var(--ink-soft);
    max-width: 44rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
