---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { resourcePages, getResourcePage } from "../../data/resources";

export function getStaticPaths() {
  return resourcePages.map((page) => ({
    params: { slug: page.slug },
  }));
}

const { slug } = Astro.params;
const page = getResourcePage(slug!);

if (!page) {
  throw new Error(`Unknown resource page: ${slug}`);
}

const typeEmoji: Record<string, string> = {
  Organization: "🏛️",
  Guide: "📘",
  Helpline: "☎️",
  Reading: "📰",
  Tool: "🧰",
};

function regionId(title: string) {
  return title
    .toLowerCase()
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/^-|-$/g, "");
}

const regions = [...new Set(page.links.map((link) => link.region))].map(
  (region) => ({
    title: region,
    countries: [
      ...new Set(
        page.links
          .filter((link) => link.region === region)
          .map((link) => link.country),
      ),
    ].map((country) => ({
      title: country,
      links: page.links.filter(
        (link) => link.region === region && link.country === country,
      ),
    })),
  }),
);
---

<BaseLayout title={page.title} description={page.intro}>
  <section class="page-hero">
    <div class="wrap">
      <p class="eyebrow animate-rise"><a href="/resources/">📚 Resources</a></p>
      <h1 class="animate-rise animate-rise-delay-1">{page.title}</h1>
      <p class="intro animate-rise animate-rise-delay-2">{page.intro}</p>
    </div>
  </section>

  <section class="section">
    <div class="wrap">
      {page.note && <p class="note">{page.note}</p>}
      <nav class="region-nav" aria-label="Resource regions">
        <span>🧭 Jump to:</span>
        {
          regions.map((region) => (
            <a href={`#${regionId(region.title)}`}>{region.title}</a>
          ))
        }
      </nav>
      <div class="regions">
        {
          regions.map((region) => (
            <section class="region-section" id={regionId(region.title)}>
              <h2>{region.title}</h2>
              {region.countries.map((country) => (
                <section class="country-section">
                  <h3>{country.title}</h3>
                  <ul class="resource-list">
                    {country.links.map((link) => (
                      <li>
                        <article class="resource">
                          <div class="resource-top">
                            <span class="type">
                              {typeEmoji[link.type] ?? "📌"} {link.type}
                            </span>
                            <h4>
                              <a
                                href={link.href}
                                target="_blank"
                                rel="noopener noreferrer"
                              >
                                {link.title} ↗
                              </a>
                            </h4>
                          </div>
                          <p>{link.description}</p>
                        </article>
                      </li>
                    ))}
                  </ul>
                </section>
              ))}
            </section>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-hero {
    padding: 5rem 0 2rem;
    border-bottom: 1px solid var(--line);
    background:
      linear-gradient(180deg, color-mix(in oklab, var(--foam) 45%, transparent), transparent);
  }

  .eyebrow {
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-size: 0.85rem;
    margin-bottom: 0.6rem;
  }

  .eyebrow a {
    text-decoration: none;
    color: var(--sea-deep);
  }

  .eyebrow a:hover {
    text-decoration: underline;
  }

  h1 {
    font-size: clamp(2.2rem, 6vw, 3.6rem);
  }

  .intro {
    max-width: 42rem;
    color: var(--ink-soft);
    font-size: 1.1rem;
  }

  .note {
    max-width: 44rem;
    padding: 0.9rem 1.1rem;
    margin-bottom: 2rem;
    border-left: 3px solid var(--sun);
    background: color-mix(in oklab, var(--sun) 12%, transparent);
    color: var(--ink);
    font-size: 0.97rem;
  }

  .region-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem 1rem;
    margin-bottom: 3rem;
    font-size: 0.9rem;
  }

  .region-nav span {
    font-weight: 700;
    color: var(--ink);
  }

  .region-nav a {
    color: var(--sea-deep);
    font-weight: 700;
    text-decoration: none;
  }

  .region-nav a:hover {
    text-decoration: underline;
  }

  .regions {
    display: grid;
    gap: 4rem;
  }

  .region-section {
    scroll-margin-top: 6rem;
  }

  .region-section > h2 {
    font-size: clamp(1.8rem, 4vw, 2.5rem);
    padding-bottom: 0.8rem;
    margin-bottom: 2rem;
    border-bottom: 2px solid var(--ink);
  }

  .country-section + .country-section {
    margin-top: 2.75rem;
  }

  .country-section h3 {
    font-size: clamp(1.35rem, 3vw, 1.75rem);
    color: var(--sea-deep);
    margin-bottom: 1rem;
  }

  .resource-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 1.75rem;
  }

  .resource {
    padding-bottom: 1.75rem;
    border-bottom: 1px solid var(--line);
  }

  .resource-top {
    display: grid;
    gap: 0.35rem;
    margin-bottom: 0.55rem;
  }

  .type {
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--sea-deep);
  }

  h4 {
    font-family: var(--font-display);
    font-size: clamp(1.2rem, 2.5vw, 1.5rem);
    line-height: 1.15;
    letter-spacing: -0.03em;
    margin: 0;
  }

  h4 a {
    text-decoration: none;
    color: var(--ink);
  }

  h4 a:hover {
    color: var(--sea-deep);
  }

  .resource p {
    color: var(--ink-soft);
    max-width: 42rem;
    margin: 0;
  }

  @media (min-width: 900px) {
    .resource-list {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      column-gap: 2.5rem;
    }
  }
</style>
