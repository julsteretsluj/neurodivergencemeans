---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { categories } from "../../data/categories";
import { postsByCategory } from "../../data/posts";
---

<BaseLayout title="Categories" description="Browse Neurodivergence Means posts by topic.">
  <section class="page-hero">
    <div class="wrap">
      <h1 class="animate-rise">Categories</h1>
      <p class="animate-rise animate-rise-delay-1">
        Topics used across the Instagram feed — open a category to see related posts and jump back to Instagram.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="wrap">
      <ul class="grid">
        {
          categories.map((category) => {
            const count = postsByCategory(category.slug).length;
            return (
              <li>
                <a class="category" href={`/categories/${category.slug}/`} style={`--accent: ${category.accent}`}>
                  <span class="count">{count} posts</span>
                  <h2>{category.title}</h2>
                  <p>{category.summary}</p>
                </a>
              </li>
            );
          })
        }
      </ul>
    </div>
  </section>
</BaseLayout>

<style>
  .page-hero {
    padding: 5rem 0 1rem;
    border-bottom: 1px solid var(--line);
    background:
      linear-gradient(180deg, color-mix(in oklab, var(--sun) 12%, transparent), transparent);
  }

  h1 {
    font-size: clamp(2.4rem, 7vw, 4rem);
  }

  .page-hero p {
    max-width: 36rem;
    color: var(--ink-soft);
    font-size: 1.15rem;
  }

  .grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 1rem;
  }

  .category {
    display: grid;
    gap: 0.45rem;
    padding: 1.4rem 0;
    border-top: 1px solid var(--line);
    text-decoration: none;
    color: inherit;
  }

  .grid li:last-child .category {
    border-bottom: 1px solid var(--line);
  }

  .count {
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--accent);
  }

  h2 {
    font-size: clamp(1.6rem, 3.5vw, 2.1rem);
    margin: 0;
  }

  .category p {
    margin: 0;
    color: var(--ink-soft);
    max-width: 34rem;
  }

  .category:hover h2 {
    color: var(--accent);
  }

  @media (min-width: 860px) {
    .grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      column-gap: 2.5rem;
    }
  }
</style>
